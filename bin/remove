#!/usr/bin/env bash

set -euo pipefail

# Colors
green='\033[0;32m'
red='\033[0;31m'
nc='\033[0m'

log() { echo -e "${green}==>${nc} ${1}"; }
error() { echo -e "${red}Error:${nc} ${1}" >&2; exit 1; }

parse_arguments() {
  if [ -z "${1:-}" ]; then
    echo "Usage: bin/remove <submodule-path>"
    echo ""
    echo "  submodule-path  Path to the submodule to remove"
    echo ""
    echo "Examples:"
    echo "  bin/remove rails-apps/fizzy"
    exit 1
  fi

  path="$1"
}

parse_arguments "$@"

if [ ! -d "$path" ]; then
  error "$path does not exist"
fi

git submodule deinit -f "$path"
git rm -f "$path"
rm -rf ".git/modules/$path"
git commit -m "Remove $path submodule"
log "Removed $path submodule."
